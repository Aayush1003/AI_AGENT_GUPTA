# ========================================
# API Configuration
# ========================================
GEMINI_API_KEY=your_gemini_api_key_here
PORT=5000
NODE_ENV=development

# ========================================
# Database Configuration (Choose ONE)
# ========================================
# DB_TYPE options: 'local' (default), 'firebase', or 'mongodb'
DB_TYPE=local

# MongoDB Configuration (if using mongodb)
# For local: mongodb://localhost:27017/ai-agent
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/ai-agent
# MONGODB_URI=mongodb://localhost:27017/ai-agent-db

# Firebase Configuration (if using firebase)
# Option 1: Path to firebase-key.json file
# FIREBASE_KEY_PATH=./firebase-key.json
# Option 2: Entire JSON as environment variable
# FIREBASE_KEY={"type":"service_account","project_id":"..."}

# ========================================
# Security & JWT
# ========================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# ========================================
# CORS
# ========================================
CORS_ORIGIN=http://localhost:3000

# ========================================
# Google OAuth (Phase 3)
# ========================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Vector DB (Phase 2)
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_ENVIRONMENT=your_pinecone_env_here
