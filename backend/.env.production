# ========== CRITICAL - Set in GitHub Secrets ==========
# Get from: https://ai.google.dev/
GEMINI_API_KEY=${GEMINI_API_KEY}

# ========== SERVER CONFIGURATION ==========
PORT=5000
NODE_ENV=production

# ========== DATABASE CONFIGURATION ==========
# Using Firebase (recommended for production)
DB_TYPE=firebase

# Firebase service account key (JSON as environment variable)
# Set in GitHub Secrets as JSON string, then parse at runtime
FIREBASE_CONFIG=${FIREBASE_CONFIG}

# Alternative: For MongoDB (if switching databases)
# DB_TYPE=mongodb
# MONGODB_URI=${MONGODB_URI}

# ========== SECURITY - Set in GitHub Secrets ==========
# Generate secure random strings for sensitive keys
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRY=7d

# ========== CORS & FRONTEND COMMUNICATION ==========
# This will be set to your deployed Vercel/Netlify frontend URL
# Example: https://my-app.vercel.app
CORS_ORIGIN=${CORS_ORIGIN}

# ========== LOGGING ==========
LOG_LEVEL=info

# ========== OPTIONAL: Phase 3 Features ==========
# Uncomment and configure when implementing Phase 3

# Google OAuth (optional for user authentication)
# GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}
# GOOGLE_CLIENT_SECRET=${GOOGLE_CLIENT_SECRET}

# Pinecone (optional for semantic search)
# PINECONE_API_KEY=${PINECONE_API_KEY}
# PINECONE_ENVIRONMENT=${PINECONE_ENVIRONMENT}

# Sentry (optional for error tracking)
# SENTRY_DSN=${SENTRY_DSN}
